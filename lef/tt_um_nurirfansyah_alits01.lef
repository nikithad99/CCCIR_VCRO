VERSION 5.7 ;
BUSBITCHARS "[]" ;
DIVIDERCHAR "/" ;

MACRO tt_um_nurirfansyah_alits01
  CLASS BLOCK ;
  ORIGIN 0 0 ;
  SIZE 161.00 BY 225.76 ;

  SITE unithd ;

  # --------------------
  # POWER PINS
  # --------------------
  PIN VPWR
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER met4 ;
        RECT 1.00 5.00 2.50 220.76 ;
    END
  END VPWR

  PIN VGND
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER met4 ;
        RECT 49.00 5.00 50.50 220.76 ;
    END
  END VGND

  # --------------------
  # CLOCK / CONTROL
  # --------------------
  PIN clk
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER met4 ;
        RECT 154.80 224.50 155.30 225.50 ;
    END
  END clk

  PIN ena
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER met4 ;
        RECT 158.50 224.50 159.00 225.50 ;
    END
  END ena

  PIN rst_n
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER met4 ;
        RECT 151.10 224.50 151.60 225.50 ;
    END
  END rst_n

  # --------------------
  # DIGITAL OUTPUTS
  # --------------------
  PIN uo_out[0]
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    PORT
      LAYER met4 ;
        RECT 88.50 224.50 89.00 225.50 ;
    END
  END uo_out[0]

  PIN uo_out[1]
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    PORT
      LAYER met4 ;
        RECT 84.90 224.50 85.40 225.50 ;
    END
  END uo_out[1]

  PIN uo_out[2]
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    PORT
      LAYER met4 ;
        RECT 81.20 224.50 81.70 225.50 ;
    END
  END uo_out[2]

  PIN uo_out[3]
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    PORT
      LAYER met4 ;
        RECT 77.50 224.50 78.00 225.50 ;
    END
  END uo_out[3]

  PIN uo_out[4]
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    PORT
      LAYER met4 ;
        RECT 73.90 224.50 74.40 225.50 ;
    END
  END uo_out[4]

  PIN uo_out[5]
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    PORT
      LAYER met4 ;
        RECT 70.20 224.50 70.70 225.50 ;
    END
  END uo_out[5]

  # --------------------
  # ANALOG PINS
  # --------------------
  PIN ua[0]
    DIRECTION INOUT ;
    USE SIGNAL ;
    PORT
      LAYER met4 ;
        RECT 156.50 0.00 157.00 1.00 ;
    END
  END ua[0]

  PIN ua[1]
    DIRECTION INOUT ;
    USE SIGNAL ;
    PORT
      LAYER met4 ;
        RECT 134.40 0.00 134.90 1.00 ;
    END
  END ua[1]

  PIN ua[2]
    DIRECTION INOUT ;
    USE SIGNAL ;
    PORT
      LAYER met4 ;
        RECT 112.30 0.00 112.80 1.00 ;
    END
  END ua[2]

END tt_um_nurirfansyah_alits01

END LIBRARY
